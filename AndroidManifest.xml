<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.sanaya.assistant">

    <application
        android:allowBackup="true"
        android:label="Sanaya AI"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <!-- Sanaya's Security Guard (Accessibility Service) -->
        <service
            android:name=".service.AccessibilityHelperService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Sanaya's Voice (Broadcast Receiver) -->
        <receiver
            android:name=".receiver.SanayaVoiceReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.sanaya.ACTION_SPEAK" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
